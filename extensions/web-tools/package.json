{
  "name": "web-tools",
  "version": "0.1.0",
  "description": "Websearch and webfetch Pi tools used by the oak-pi package",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src/",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
