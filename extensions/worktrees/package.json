{
  "name": "pi-worktrees",
  "version": "1.0.0",
  "description": "Pi extension for creating git worktrees with session handoff support",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src/",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "bunx tsc --noEmit -p tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@mariozechner/pi-tui": "^0.62.0",
    "@types/node": "^24.6.0",
    "bun-types": "^1.3.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  },
  "license": "MIT"
}
